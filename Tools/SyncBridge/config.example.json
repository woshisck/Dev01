{
    "git": {
        "repo_path": "D:\\GitRepo\\Dev01",
        "branch": "main",
        "remote": "origin"
    },

    "p4": {
        "port": "ssl:your-p4-server:1666",
        "user": "your_p4_username",
        "password": "",
        "workspace": "your_workspace_name",
        "workspace_path": "D:\\P4Workspace\\Dev01",
        "depot_path": "//depot/Dev01/...",
        "charset": ""
    },

    "ue5": {
        "enabled": true,
        "engine_path": "D:\\UE\\UE_5.4",
        "project_file": "DevKit.uproject",
        "target": "DevKitEditor",
        "platform": "Win64",
        "configuration": "Development",
        "dotnet_version": "6.0.302",
        "compile_triggers": [".cpp", ".h", ".cs", ".Build.cs"],
        "compile_output_dirs": ["Binaries"]
    },

    "poll_interval_minutes": 10,
    "log_file": "sync_bridge.log",
    "log_level": "INFO",

    "ignore_patterns": [
        ".git",
        "Intermediate",
        "Saved",
        "DerivedDataCache",
        ".vs",
        "__pycache__",
        "*.sln"
    ]
}